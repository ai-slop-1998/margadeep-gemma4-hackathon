# Copy to /etc/margadeep/margadeep.env on the VM and edit values.

MARGADEEP_REPO_DIR=/opt/margadeep/app
MARGADEEP_BACKEND_DIR=/opt/margadeep/app/apps/backend
MARGADEEP_BACKEND_VENV=/opt/margadeep/app/apps/backend/.venv
MARGADEEP_KG_MEMORY_DIR=/opt/margadeep/kg_memory
MARGADEEP_LOG_DIR=/var/log/margadeep

PYTHONPATH=/opt/margadeep/app/apps/backend
LOCAL_POC_PG_DATABASE=margadeep_poc
PGDATABASE=margadeep_poc
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=margadeep
PGPASSWORD=change-this-demo-password
LOCAL_POC_PSQL_PATH=/usr/bin/psql
LOCAL_EMBEDDING_MODEL_PATH=/opt/margadeep/app/.local/models/embeddinggemma-300m

MCP_SERVER_URL=http://127.0.0.1:8001/mcp
GEMMA4_ADK_BASE_URL=http://127.0.0.1:8082
GEMMA4_ADK_APP_NAME=offline_prep
GEMMA4_PREPARE_USER_ID=local-caregiver
GEMMA4_KG_MEMORY_DIR=/opt/margadeep/kg_memory

OFFLINE_SUPPORT_RESPONSE_MODE=a2ui
OFFLINE_SUPPORT_ENABLE_CLARIFICATION=true
OFFLINE_SUPPORT_CLARIFICATION_MAX_ROUNDS=1
OFFLINE_SUPPORT_ENABLE_PLAN_REVIEW=true
OFFLINE_SUPPORT_PLAN_REVIEW_MAX_TURNS=1
OFFLINE_SUPPORT_ENABLE_RESEARCH_AFTER_PLANNING=true
RESEARCH_ENABLE_LOOP=false
RESEARCH_MAX_ITERATIONS=2
RESEARCH_SKIP_PLANNER=false

# Demo default: deterministic online cards are cheaper and more stable.
GEMMA4_ONLINE_SUPPORT_USE_MODEL=false
GEMMA4_ONLINE_OUTCOME_RUN_AUTOSCHEMA=true
GEMMA4_LIVE_SUMMARY_USE_MODEL=auto
GEMMA4_REFLECT_USE_MODEL=false
GEMMA4_PREPARE_REVIEW_USE_MODEL=false

# Vertex mode. Keep this if you call Vertex-hosted Gemini/Gemma models.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=replace-with-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
GEMMA4_VERTEX_EVAL_MODEL=replace-with-vertex-model

# Local vLLM mode for ADK agents. Enable this once vLLM is running.
# For Gemma 4 E2B/MTP container serving, use model name `openapi` unless you
# override VLLM_SERVED_MODEL_NAME in the serving container.
# GEMMA4_ADK_MODEL_PROVIDER=litellm
# GEMMA4_LITELLM_MODEL=openai/openapi
# OPENAI_API_BASE=http://127.0.0.1:8000/v1
# OPENAI_API_KEY=local-vllm
# RESEARCH_WEAK_MODEL=openapi
# RESEARCH_CRITIC_MODEL=openapi
# RESEARCH_PLANNER_MODEL=openapi
# OFFLINE_SUPPORT_CLARIFIER_MODEL=openapi
# GEMMA4_ONLINE_SUPPORT_MODEL=openapi

# AutoSchemaKG through local vLLM instead of Vertex.
# GEMMA4_KG_LLM_PROVIDER=vllm
# GEMMA4_KG_LLM_MODEL=openapi
# GEMMA4_KG_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# GEMMA4_KG_OPENAI_API_KEY=local-vllm
GEMMA4_KG_INCLUDE_CONCEPTS=true
GEMMA4_KG_MAX_WORKERS=1
GEMMA4_KG_MAX_NEW_TOKENS=8192

# vLLM service settings. Exact model id depends on the Gemma artifact you can access.
VLLM_HOST=127.0.0.1
VLLM_PORT=8000
VLLM_MODEL=google/gemma-4-E2B-it
VLLM_SERVED_MODEL_NAME=openapi
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.90

# Gemma 4 container serving mode. This uses
# infra/deploy/gemma4-serving/e2b-mtp and is intended for 1 x NVIDIA L4 or conservative single V100.
# Set VLLM_CONTAINER_IMAGE_URI to a locally built or Artifact Registry image.
# VLLM_SERVING_MODE=container
# VLLM_CONTAINER_IMAGE_URI=gemma-e2b-mtp-vllm:local
# VLLM_CONTAINER_NAME=margadeep-gemma4-vllm
# VLLM_GPU_DEVICES=device=0
# VLLM_TENSOR_PARALLEL_SIZE=1
# VLLM_ENABLE_MTP=1
# VLLM_SPECULATIVE_ASSISTANT_MODEL=google/gemma-4-E2B-it-assistant
# VLLM_SPECULATIVE_NUM_TOKENS=4
# VLLM_QUANTIZATION=none
# VLLM_KV_CACHE_DTYPE=auto
# HF_TOKEN_SECRET_RESOURCE=projects/PROJECT_NUMBER/secrets/HF_TOKEN_SECRET/versions/latest
